rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().uid == request.auth.uid
        && incoming().email is string
        && incoming().createdAt == request.time;
      allow update: if isOwner(userId)
        && incoming().uid == existing().uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
    }

    // --- Resumes ---
    function isValidResume(data) {
      return data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 200
        && data.data is map
        && data.templateId is string;
    }

    match /resumes/{resumeId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(resumeId)
        && isValidResume(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isSignedIn()
        && existing().userId == request.auth.uid
        && isValidResume(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
